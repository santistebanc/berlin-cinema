# TMDb API Key — get yours free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OMDb API Key — get yours free at https://www.omdbapi.com/apikey.aspx
# Used to fetch IMDb ratings, vote counts, and Rotten Tomatoes / Metacritic scores
OMDB_API_KEY=your_omdb_api_key_here
